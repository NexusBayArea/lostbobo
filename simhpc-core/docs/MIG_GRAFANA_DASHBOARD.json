{
  "title": "SimHPC — Full GPU + MIG Monitoring",
  "uid": "simhpc-gpu-mig-v3",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "title": "Overall Cluster GPU Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "count(DCGM_FI_DEV_GPU_UTIL)" }]
    },
    {
      "title": "Active MIG Instances",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "count(DCGM_FI_DEV_MIG_PROFILE)" }]
    },
    {
      "title": "Average GPU Utilization",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "avg(DCGM_FI_DEV_GPU_UTIL)" }]
    },
    {
      "title": "MIG Profile Switches (24h)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "increase(mig_profile_switches_total[24h])" }]
    },
    {
      "title": "GPU Utilization by Instance",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "targets": [
        { "expr": "DCGM_FI_DEV_GPU_UTIL", "legendFormat": "{{ instance }} {{ profile }}" }
      ]
    },
    {
      "title": "GPU Memory Utilization (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "targets": [
        { "expr": "DCGM_FI_DEV_MEM_COPY_UTIL", "legendFormat": "{{ instance }}" }
      ]
    },
    {
      "title": "MIG Profile Distribution",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 9 },
      "targets": [
        { "expr": "sum by (profile) (DCGM_FI_DEV_MIG_PROFILE)", "legendFormat": "{{ profile }}" }
      ]
    },
    {
      "title": "Fractional GPU Allocation",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 9 },
      "targets": [
        { "expr": "simhpc_fractional_gpu_utilization", "legendFormat": "Fractional Usage" }
      ]
    },
    {
      "title": "MPS Active Clients",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 9 },
      "targets": [
        { "expr": "mps_active_clients", "legendFormat": "Active MPS Clients" }
      ]
    },
    {
      "title": "Top 10 Hot MIG Nodes",
      "type": "table",
      "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "targets": [
        { "expr": "topk(10, DCGM_FI_DEV_GPU_UTIL{instance=~\".*mig.*\"})" }
      ]
    }
  ]
}
