# =============================================================
# 1. FRONTEND IDENTITY (Publicly Visible)
# =============================================================
# Use 'VITE_' prefix for Vite/React (SimHPC standard)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

# The URL of your RunPod GPU API (obtained from RunPod HTTP Proxy mapping)
# Use the stable Proxy URL (Port 80/443) to avoid IP-change "Offline" issues
VITE_GPU_WORKER_URL="https://73atszmbozf16d-8000.proxy.runpod.net"
VITE_API_URL="https://73atszmbozf16d-8000.proxy.runpod.net"

# =============================================================
# 2. AUTHENTICATION (Google & Supabase Auth)
# =============================================================
# Google Cloud Console > APIs & Services > Credentials
# Authorized JavaScript Origins: https://your-app-name.vercel.app
# Authorized Redirect URIs: https://your-app-name.vercel.app/api/auth/callback/google
VITE_GOOGLE_CLIENT_ID="your-id.apps.googleusercontent.com"

# =============================================================
# 3. BACKEND & PAYMENTS (Server-Side Only - HIDDEN)
# =============================================================
# DO NOT prefix these with VITE_
# Used by RunPod Worker to bypass RLS for administrative updates
SUPABASE_SERVICE_ROLE_KEY="your-admin-only-key"

# Payments & Billing
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Mercury AI / LLM Access (Inception Labs)
MERCURY_API_KEY="ms_live_..."
SIMHPC_API_KEY="your-internal-secure-key"

# =============================================================
# 4. INFRASTRUCTURE & SCALING
# =============================================================
REDIS_URL="redis://user:password@public-redis-host:port/0"
RUNPOD_API_KEY="api_..."
RUNPOD_POD_ID="73atszmbozf16d"
MAX_PODS=2
IDLE_TIMEOUT_SEC=300
