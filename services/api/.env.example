# --- DATABASE & STORAGE ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...
# Used to verify the JWT from the frontend
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_settings

# --- REDIS (Simulation Queue) ---
REDIS_URL=redis://localhost:6379

# --- STRIPE (Billing Verification) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- API SECURITY ---
SIMHPC_API_KEY=your_api_key_here
ADMIN_SECRET=your_admin_secret_here

# --- RUNPOD FLEET MANAGEMENT (v2.2.0) ---
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_POD_ID=s29bwh3k8f0pho
RUNPOD_GPU_TYPE=NVIDIA A40
RUNPOD_WORKER_IMAGE=simhpcworker/simhpc-worker:v2
