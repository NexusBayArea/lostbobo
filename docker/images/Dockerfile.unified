# ═══════════════════════════════════════════════════════════
# SimHPC Unified Dockerfile (v2.7.1)
# Optimized for: deterministic builds, minimal runtime, security
# Build: docker build -f docker/images/Dockerfile.unified -t simhpcworker/simhpc-unified:latest .
# ═══════════════════════════════════════════════════════════

FROM nvidia/cuda:12.2.0-runtime-ubuntu22.04 AS base

# ───────────────────────────────────────────────────────────
# Stage 1: Base - System dependencies & security hardening
# ───────────────────────────────────────────────────────────

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    APP_HOME=/app \
    PYTHONPATH=/app \
    HF_HOME=/workspace/huggingface \
    VLLM_CACHE=/workspace/vllm_cache

WORKDIR $APP_HOME

# Install system dependencies including supervisor and tini
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-dev \
    curl \
    bash \
    psmisc \
    supervisor \
    tini \
    && rm -rf /var/lib/apt/lists/*

# Upgrade pip
RUN pip3 install --no-cache-dir --upgrade pip setuptools>=78.1.1 wheel>=0.38.1

# Create non-root user for security
RUN useradd -m -u 10001 simuser && \
    mkdir -p $APP_HOME && \
    chown -R simuser:simuser $APP_HOME

# ───────────────────────────────────────────────────────────
# Stage 2: Dependencies - Cached layer for pip packages
# ───────────────────────────────────────────────────────────

FROM base AS builder

# Copy requirements files from app/services/worker
COPY --chown=simuser:simuser app/services/worker/requirements.txt ./req-worker.txt
COPY --chown=simuser:simuser app/services/worker/requirements-autoscaler.txt ./req-auto.txt
COPY --chown=simuser:simuser app/api/requirements.txt ./req-api.txt

# Install Python dependencies
RUN pip3 install --no-cache-dir -r req-worker.txt && \
    pip3 install --no-cache-dir -r req-auto.txt && \
    pip3 install --no-cache-dir -r req-api.txt

# Verify critical packages installed
RUN python3 -c "import fastapi, redis, pydantic, httpx, supabase; print('✓ Core dependencies OK')"

# ───────────────────────────────────────────────────────────
# Stage 3: Runtime - Final optimized image
# ───────────────────────────────────────────────────────────

FROM base AS runtime

# Copy Python dependencies from builder
COPY --from=builder /usr/local /usr/local

# Copy App files (api.py in app/api/, worker.py in app/services/worker/)
COPY --chown=simuser:simuser app/ ./app/

# Copy start script from app/services/worker/start.sh
COPY --chown=simuser:simuser app/services/worker/start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Switch to non-root user
USER simuser

# ───────────────────────────────────────────────────────────
# Health Checks
# ───────────────────────────────────────────────────────────

# Health check: Verify API is responding on port 8080 (primary)
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/api/v1/health || exit 1

# ───────────────────────────────────────────────────────────
# Expose Ports
# ───────────────────────────────────────────────────────────

EXPOSE 8080

# ───────────────────────────────────────────────────────────
# Startup Command - Unified (API + Worker + Autoscaler)
# ───────────────────────────────────────────────────────────

ENTRYPOINT ["/app/start.sh"]
