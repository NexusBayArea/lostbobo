# SimHPC Worker - v2.7.4 (Unified Base)
FROM simhpcworker/simhpc-base:latest

WORKDIR /app

# Install worker and gpu extras
RUN uv pip install --system --no-cache .[worker,gpu]

# Copy application code
COPY app/ ./app/

# Setup Non-Root User
RUN useradd -m simuser && chown -R simuser:simuser /app
USER simuser

EXPOSE 8080

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python3", "app/services/worker/worker.py"]
