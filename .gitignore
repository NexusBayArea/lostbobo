# ==============================================================================
# SimHPC .gitignore — SECURITY HARDENED
# ==============================================================================

# ==============================================================================
# CORE SYSTEM (NEVER PUBLIC) — Execution Brain
# ==============================================================================
app/
worker/
autoscaler/
ci/
tools/
infra/
docker/
scripts/
runtime/
packages/

# ==============================================================================
# DEPLOYMENT & ORCHESTRATION
# ==============================================================================
.github/workflows/
docker-compose*.yml
supervisord.conf

# ==============================================================================
# DEPENDENCY & BUILD SYSTEM (REPRODUCIBILITY)
# ==============================================================================
requirements*.txt
uv.lock
poetry.lock
pyproject.toml
pytest.ini
.ruff.toml
.mypy_cache/

# ==============================================================================
# ENVIRONMENT & SECRETS (CRITICAL)
# ==============================================================================
.env
.env.*
.env.local
.env.production.local
*.pem
*.key
*.pub
secrets/
credentials/
INFISICAL_SECRETS_TEMPLATE.md

# ==============================================================================
# LOCAL / IDE
# ==============================================================================
.vscode/
.idea/
.DS_Store
*.sqlite
*.db

# ==============================================================================
# PYTHON
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.pytest_cache/
.ruff_cache/

# ==============================================================================
# NODE / FRONTEND ONLY
# ==============================================================================
node_modules/
dist/
build/
.vercel/
.next/
*.tsbuildinfo

# ==============================================================================
# DATA & LOGS
# ==============================================================================
data/
logs/
*.log
outputs/
results/
legacy_archive/

# ==============================================================================
# DOCUMENTATION (Sanitized versions only)
# ==============================================================================
*.md
!README.md
!CHANGELOG.md
